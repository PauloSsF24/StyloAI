generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Look {
  id          String   @id @default(uuid())
  imageUrl    String
  nome    String
  clima     String   // cold | mild | hot
  ocasiao    String   // casual | formal | work
  lastUsedAt  DateTime?
  rating      Int      @default(0)
  createdAt   DateTime @default(now())
}